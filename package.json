{
  "name": "flodok",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "gen:types": "supabase gen types typescript --linked --schema public > src/types/database.ts"
  },
  "dependencies": {
