  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.2",
    "@eslint/js": "^9.39.4",
    "@types/diff": "^7.0.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
